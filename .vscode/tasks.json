{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run CKKS Tests",
            "type": "shell",
            "command": "${workspaceFolder}/venv/bin/python",
            "args": [
                "-m", "pytest", 
                "ckks/test_ckks.py", 
                "-v"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": []
        },
        {
            "label": "Run CKKS Tests with Coverage",
            "type": "shell",
            "command": "${workspaceFolder}/venv/bin/python",
            "args": [
                "-m", "pytest", 
                "ckks/test_ckks.py", 
                "-v", 
                "--cov=ckks.ckks_main",
                "--cov-report=term-missing"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "presentation": {
